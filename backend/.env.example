# API配置
API_HOST=0.0.0.0
API_PORT=9000

# AI模型配置 - 支持OpenAI兼容的API
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.deepseek.com  # 或其他兼容OpenAI的API
MODEL_NAME=deepseek-chat  # 可用: deepseek-chat, gpt-4o-mini, llama3 等

# 嵌入模型配置
EMBEDDING_MODEL=deepseek-embedding  # 或 text-embedding-3-small, mxbai-embed-large 等

# 网络搜索配置 - Tavily
# 获取API密钥: https://tavily.com/
SEARCH_API_KEY=your_tavily_api_key

# 数据库配置
DATABASE_URL=sqlite:///./rag.db

# ChromaDB配置
CHROMA_DB_PATH=./chroma_db
