# API配置
API_HOST=0.0.0.0
API_PORT=9000

# AI模型配置 - 支持OpenAI兼容的API
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1  # 或其他兼容OpenAI的API (如 DeepSeek: https://api.deepseek.com)
MODEL_NAME=gpt-4o-mini  # 可用: gpt-4o-mini, deepseek-chat, llama3 等

# 嵌入模型配置
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI 嵌入模型
# 注意: DeepSeek 目前不提供嵌入服务，如果使用 DeepSeek 聊天，嵌入可使用 OpenAI 服务
# 如果使用不同的 API 进行嵌入，请配置:
# EMBEDDING_API_KEY=your_embedding_api_key
# EMBEDDING_API_BASE=https://api.openai.com/v1

# 重排序模型配置 (可选，提升检索精度)
# 推荐使用 SiliconFlow 的 bge-reranker 模型
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_API_KEY=your_rerank_api_key
# RERANK_API_BASE=https://api.siliconflow.cn/v1

# 网络搜索配置 - Tavily
# 获取API密钥: https://tavily.com/
SEARCH_API_KEY=your_tavily_api_key

# 数据库配置
DATABASE_URL=sqlite:///./rag.db

# ChromaDB配置
CHROMA_DB_PATH=./chroma_db
