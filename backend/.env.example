# API配置
API_HOST=0.0.0.0
API_PORT=8000

# AI模型配置
OPENAI_API_KEY=your_api_key
OPENAI_API_BASE=http://localhost:11434/v1  # Ollama
MODEL_NAME=gpt-4o-mini

# 嵌入模型配置
