# API配置
API_HOST=0.0.0.0
API_PORT=9000

# AI模型配置 - 支持OpenAI兼容的API
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# 嵌入模型配置
EMBEDDING_MODEL=text-embedding-3-small
# 如需使用不同的嵌入API:
# EMBEDDING_API_KEY=your_embedding_api_key
# EMBEDDING_API_BASE=https://api.openai.com/v1

# 重排序模型配置 (可选)
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_API_KEY=your_rerank_api_key
# RERANK_API_BASE=https://api.siliconflow.cn/v1

# 网络搜索配置 - Tavily (可选)
# 获取API密钥: https://tavily.com/
# SEARCH_API_KEY=your_tavily_api_key

# JWT认证配置 (生产环境必须设置强密钥)
JWT_SECRET_KEY=your-strong-secret-key-at-least-32-chars

# 数据库配置
DATABASE_URL=sqlite:///./rag.db

# ChromaDB配置
CHROMA_DB_PATH=./chroma_db

# Mem0 长期记忆配置
MEM0_ENABLED=false
MEM0_QDRANT_PATH=./mem0_qdrant
MEM0_QDRANT_COLLECTION=agentic_rag_user_memories_bge_m3_v1
MEM0_LLM_PROVIDER=deepseek
MEM0_LLM_MODEL=deepseek-chat
MEM0_LLM_API_KEY=your_mem0_llm_api_key
MEM0_LLM_BASE_URL=https://api.deepseek.com
MEM0_EMBEDDER_PROVIDER=openai
MEM0_EMBEDDER_MODEL=BAAI/bge-m3
MEM0_EMBEDDER_API_KEY=your_mem0_embedder_api_key
MEM0_EMBEDDER_BASE_URL=https://api.siliconflow.cn/v1
MEM0_EMBEDDER_DIMS=1024
MEM0_CUSTOM_INSTRUCTIONS=请始终使用简体中文保存记忆。记忆应简洁、准确，只保留跨会话仍然有用的长期信息。不要保存一次性任务、临时问题、API Key、密码、令牌或其他敏感信息。
